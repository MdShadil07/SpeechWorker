# Speech Worker Deployment Environment Variables
HOST=0.0.0.0
PORT=8001
LOG_LEVEL=INFO

# Whisper Configuration
WHISPER_MODEL=tiny.en
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# Security
# Set this to the domain of the main backend or UI making requests to this worker.
ALLOWED_ORIGINS=http://localhost:5000,http://127.0.0.1:5000
